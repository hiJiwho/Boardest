rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if true;
    }

    match /teachers_cloud/{document=**} {
      allow read, write: if true;
    }

    match /cloud_connections/{document=**} {
      allow read, write: if true;
    }

    match /eat_calls/{callId} {
      allow read, write: if true;
    }
  }
}
