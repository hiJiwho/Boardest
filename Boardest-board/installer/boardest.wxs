<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Boardest"
    Language="1033"
    Version="1.0.0.0"
    Manufacturer="Boardest"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package
      InstallerVersion="200"
      Compressed="yes"
      InstallScope="perMachine"
      Description="Boardest - Board Game Companion App"
      Comments="Boardest installer"
      Manufacturer="Boardest" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Boardest is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Boardest" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcutDesktop" />
      <ComponentRef Id="ApplicationShortcutStartMenu" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\License.rtf" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Install directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Boardest" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Boardest" />
      </Directory>
    </Directory>

    <!-- Shortcuts -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="ApplicationShortcutDesktop" Guid="B1C2D3E4-F5A6-7890-BCDE-F01234567891">
        <Shortcut
          Id="ApplicationShortcutDesktop"
          Name="Boardest"
          Description="Boardest Board Game Companion"
          Target="[INSTALLFOLDER]boardest.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="BoardestIcon" />
        <RemoveFolder Id="RemoveDesktopFolder" Directory="DesktopFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
          Key="Software\Boardest\Boardest"
          Name="installed_desktop"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcutStartMenu" Guid="C2D3E4F5-A6B7-8901-CDEF-012345678902">
        <Shortcut
          Id="ApplicationShortcutStartMenu"
          Name="Boardest"
          Description="Boardest Board Game Companion"
          Target="[INSTALLFOLDER]boardest.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="BoardestIcon" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
          Key="Software\Boardest\Boardest"
          Name="installed_startmenu"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Icon -->
    <Icon Id="BoardestIcon" SourceFile="$(var.SourceDir)\boardest.exe" />
    <Property Id="ARPPRODUCTICON" Value="BoardestIcon" />

  </Product>

  <!-- File components (generated by heat or manually listed) -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Main executable -->
      <Component Id="MainExecutable" Guid="D3E4F5A6-B7C8-9012-DEFA-123456789013">
        <File Id="boardestExe"
              Source="$(var.SourceDir)\boardest.exe"
              Name="boardest.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
