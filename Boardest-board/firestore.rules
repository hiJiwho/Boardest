rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 문서: Firebase Auth UID 기반
    // - 본인 문서만 읽기/수정/삭제 가능
    // - 가입 시 본인 UID로만 생성 가능
    match /users/{userId} {
      allow read:   if (request.auth != null && request.auth.uid == userId) || userId.matches('^Class\\..*');
      allow create: if (request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['teacherName', 'region', 'school', 'email']))
                    || userId.matches('^Class\\..*');
      allow update: if (request.auth != null && request.auth.uid == userId) || userId.matches('^Class\\..*');
      allow delete: if (request.auth != null && request.auth.uid == userId) || userId.matches('^Class\\..*');
    }

    // 급식 호출 / 학급 문서: 공개 읽기 및 쓰기 (전자칠판 클라이언트 비로그인 대응)
    match /eat_calls/{callId} {
      allow read, write: if true;
    }
  }
}
