{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "boardest",
    "public": "firebase_web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/sites",
        "destination": "/sites/index.html"
      },
      {
        "source": "/sites/**",
        "destination": "/sites/index.html"
      },
      {
        "source": "/sitespen",
        "destination": "/sitespen/index.html"
      },
      {
        "source": "/sitespen/**",
        "destination": "/sitespen/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
